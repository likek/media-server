{
    "compilerOptions": {
      "module": "commonjs",
      "lib": [ "es2015", "es2017", "ES2019", "dom" ],
      "target": "es5",
      "experimentalDecorators": true,
      "skipLibCheck": true,
      "outDir": "temp/vscode-dist",
      "forceConsistentCasingInFileNames": true,
      "strictNullChecks": true
    },
    "exclude": [
      "node_modules"
    ]
  }